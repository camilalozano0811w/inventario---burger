import streamlit as st
import pandas as pd
import sqlite3

# 1. Configuración básica de la página
st.set_page_config(page_title="Hand's on Burger", layout="wide")

# 2. Conexión a la base de datos (se crea automáticamente)
def conectar_db():
    conn = sqlite3.connect('burger_data.db', check_same_thread=False)
    return conn

def inicializar_tabla():
    conn = conectar_db()
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS productos (
            nombre TEXT, 
            tipo TEXT, 
            stock REAL, 
            unidad TEXT
        )
    ''')
    conn.commit()
    conn.close()

inicializar_tabla()

# 3. Control de Acceso (Login)
if 'autenticado' not in st.session_state:
    st.session_state['autenticado'] = False

if not st.session_state['autenticado']:
    st.title("🍔 Hand's on Burger")
    st.subheader("Sistema de Inventario")
    
    usuario = st.text_input("Usuario")
    clave = st.text_input("Contraseña", type="password")
    
    if st.button("Ingresar"):
        if usuario == "admin" and clave == "burger2026":
            st.session_state['autenticado'] = True
            st.rerun()
        else:
            st.error("Credenciales incorrectas")
else:
    # 4. Menú Principal una vez logueado
    st.sidebar.title("Navegación")
    opcion = st.sidebar.radio("Selecciona una sección:", 
                              ["📊 Consulta de Stock", "📝 Registrar Producto", "📉 Formato A3"])
    
    if st.sidebar.button("Cerrar Sesión"):
        st.session_state['autenticado'] = False
        st.rerun()

    # --- SECCIÓN: CONSULTA ---
    if opcion == "📊 Consulta de Stock":
        st.header("Inventario en Tiempo Real")
        conn = conectar_db()
        df = pd.read_sql_query("SELECT * FROM productos", conn)
        conn.close()
        
        if df.empty:
            st.warning("El inventario está vacío. Por favor, registra productos.")
        else:
            st.dataframe(df, use_container_width=True)

    # --- SECCIÓN: REGISTRO ---
    elif opcion == "📝 Registrar Producto":
        st.header("Agregar Nuevo Insumo")
        with st.form("formulario_registro"):
            nombre_p = st.text_input("Nombre del Insumo")
            tipo_p = st.selectbox("Categoría", ["Materia Prima", "Producto Terminado"])
            stock_p = st.number_input("Stock Inicial", min_value=0.0)
            unidad_p = st.selectbox("Unidad", ["Unidades", "Kg", "Litros", "Paquetes"])
            
            enviar = st.form_submit_button("Guardar en Inventario")
            
            if enviar:
                if nombre_p:
                    conn = conectar_db()
                    cur = conn.cursor()
                    cur.execute("INSERT INTO productos VALUES (?,?,?,?)", 
                                (nombre_p, tipo_p, stock_p, unidad_p))
                    conn.commit()
                    conn.close()
                    st.success(f"✅ {nombre_p} registrado con éxito.")
                else:
                    st.error("El nombre es obligatorio.")

    # --- SECCIÓN: FORMATO A3 ---
    elif opcion == "📉 Formato A3":
        st.header("Control Visual - Formato A3")
        col1, col2 = st.columns(2)
        with col1:
            st.info("### Problemas Identificados")
            st.write("1. Descontrol en stock de carne.")
            st.write("2. Falta de registro de mermas.")
        with col2:
            st.success("### Resultados Esperados")
            st.write("1. Reducción de desperdicios en 15%.")
            st.write("2. Toma de decisiones basada en datos.")
